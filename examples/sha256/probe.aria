// probe: test uint32 overflow behavior

use "../../stdlib/string_convert.aria".*;

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    uint32:max_val = 0xFFFFFFFFu32;
    uint32:one = 1u32;
    uint32:result = max_val + one;
    int32:r32 = result => int32;
    drop(println(int32_toString(r32)));
    exit(0);
};
