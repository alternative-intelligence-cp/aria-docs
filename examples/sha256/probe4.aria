use "../../stdlib/string_convert.aria".*;

func:failsafe = int32(tbb32:err) { exit(1); };

func:main = int32() {
    uint32[4]:arr = [0u32, 0u32, 0u32, 0u32];
    arr[0i64] = 0xDEADBEEFu32;
    arr[1i64] = 0xCAFEBABEu32;
    uint32:v0 = arr[0i64];
    uint32:v1 = arr[1i64];
    drop(println(int32_toHex(v0 => int32)));
    drop(println(int32_toHex(v1 => int32)));
    exit(0);
};
